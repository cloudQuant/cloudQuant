# =========================
# cloudQuant EditorConfig
# https://editorconfig.org
# =========================

root = true

# ----- Default settings -----
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# ----- Markdown -----
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# ----- YAML -----
[*.{yml,yaml}]
indent_size = 2

# ----- Python -----
[*.py]
indent_size = 4

# ----- JSON -----
[*.json]
indent_size = 2

# ----- Makefile -----
[Makefile]
indent_style = tab

# ----- CSV -----
[*.csv]
insert_final_newline = false

# ----- Shell scripts -----
[*.sh]
indent_size = 2

# ----- Batch files (Windows) -----
[*.bat]
end_of_line = crlf
